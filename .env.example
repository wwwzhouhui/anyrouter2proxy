# AnyRouter Proxy 配置文件（Node.js SDK 模式）
# 复制此文件为 .env 并根据需要修改配置

# ==================== Node.js 代理配置 ====================
# Node.js 代理端口（node-proxy 使用）
NODE_PROXY_PORT=4000

# Node.js 代理 URL（Python 代理连接地址）
NODE_PROXY_URL=http://127.0.0.1:4000

# ==================== Python 代理端口 ====================
# Anthropic 协议代理端口 (anyrouter2anthropic.py)
# PORT=9998

# OpenAI 协议代理端口 (anyrouter2openai.py)
# OPENAI_PROXY_PORT=9999

# Codex Responses API 代理端口 (codex_anyrouter_proxy.py)
CODEX_PROXY_PORT=9996

# 绑定地址
# HOST=0.0.0.0

# ==================== 通用配置 ====================
# HTTP 请求超时时间（秒）
# HTTP_TIMEOUT=120

# 默认最大 token 数
# DEFAULT_MAX_TOKENS=8192

# ==================== OpenAI 代理专用 ====================
# 强制使用非流式后端（解决某些流式不稳定问题）
# FORCE_NON_STREAM=false

# 默认系统提示词
# DEFAULT_SYSTEM_PROMPT=You are Claude, a helpful AI assistant.

# ==================== Codex 代理专用 ====================
# AnyRouter OpenAI 兼容端点
# ANYROUTER_OPENAI_BASE_URL=https://anyrouter.top/v1

# 可选：服务端固定使用的 AnyRouter API Key。
# 如果不设置，则透传客户端 Authorization / x-api-key。
# 支持多 key：ANYROUTER_API_KEY=sk-key1,sk-key2,sk-key3
# ANYROUTER_API_KEY=

# 对外提供给 CherryStudio / sub2api 等第三方平台使用的本地代理 Key。
# 设置后，第三方调用 /v1/* 时必须使用 Authorization: Bearer <PROXY_API_KEY>。
# 支持多 key：PROXY_API_KEY=sk-proxy-1,sk-proxy-2
# PROXY_API_KEY=

# Codex 默认模型；请求体没有 model 时自动补充
# CODEX_PROXY_MODEL=gpt-5.5

# 是否强制覆盖请求里的 model 为 CODEX_PROXY_MODEL
# CODEX_PROXY_FORCE_MODEL=false

# Codex Web 管理端登录配置
# 管理端地址：http://127.0.0.1:9996/admin
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=changeme
# ADMIN_TOKEN_SECRET=change-this-random-secret
# ADMIN_TOKEN_TTL_SECONDS=86400

# ==================== 使用说明 ====================
# 本代理服务使用透传模式，客户端必须在请求头中提供 API Key：
#
# OpenAI 协议 (anyrouter2openai.py):
#   Authorization: Bearer sk-your-api-key
#   多 key: Authorization: Bearer sk-key1,sk-key2
#
# Anthropic 协议 (anyrouter2anthropic.py):
#   x-api-key: sk-your-api-key
#   多 key: x-api-key: sk-key1,sk-key2
#
# Codex Responses API 代理 (codex_anyrouter_proxy.py):
#   推荐在服务端设置 ANYROUTER_API_KEY，然后 Codex base_url 指向 http://127.0.0.1:9996/v1
